      "header_color": "blue",
      "surface": "team_hub",
      "config_key": "database_ids.tasks",
      "data_source_config_key": "database_ids.tasks_data_source",
      "marketplace_url": "https://www.notion.so/marketplace/templates/kanban-board?cr=pro%3Anotion",
      "description": "Sprint kanban / task tracker. Status / Priority / Type / Assignee / Sprint columns + Jira link.",
      "schema": "CREATE TABLE (\"Task\" TITLE, \"Status\" STATUS, \"Priority\" SELECT('P0':red, 'P1':orange, 'P2':yellow, 'P3':gray), \"Type\" SELECT('Feature':blue, 'Bug':red, 'Chore':gray, 'Initiative':purple, 'Spike':yellow), \"Assignee\" PEOPLE, \"Sprint\" SELECT('Backlog':gray, 'Current':green, 'Next':blue), \"Due\" DATE, \"Jira Key\" RICH_TEXT, \"Task ID\" UNIQUE_ID PREFIX 'TASK', \"Created\" CREATED_TIME, \"Updated\" LAST_EDITED_TIME)"
    },
