      "description": "Triage hub for incoming requests. Items get reviewed, then promoted to Tasks.",
      "schema": "CREATE TABLE (\"Title\" TITLE, \"Type\" SELECT('Feature':blue, 'Bug':red, 'Question':yellow, 'Idea':purple), \"Severity\" SELECT('Sev1':red, 'Sev2':orange, 'Sev3':yellow, 'Sev4':gray), \"Status\" STATUS, \"Submitter\" RICH_TEXT, \"Submitter Email\" EMAIL, \"Source\" SELECT('Slack':default, 'Email':blue, 'Meeting':purple, 'Form':green, 'Other':gray), \"Description\" RICH_TEXT, \"Triaged By\" PEOPLE, \"Triaged At\" DATE, \"Intake ID\" UNIQUE_ID PREFIX 'IN', \"Created\" CREATED_TIME)"
    },
