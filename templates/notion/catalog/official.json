      "description": "Team calendar — meetings, sprint markers, holidays, releases, deadlines.",
      "schema": "CREATE TABLE (\"Event\" TITLE, \"Date\" DATE, \"Type\" SELECT('Meeting':blue, 'Sprint':purple, 'Release':green, 'Holiday':gray, 'Deadline':red, 'Other':default), \"Owner\" PEOPLE, \"Notes\" RICH_TEXT, \"Link\" URL)"
    },
