      "schema": "CREATE TABLE (\"Name\" TITLE, \"Project\" RICH_TEXT, \"Status\" STATUS, \"Priority\" SELECT('P0':red, 'P1':orange, 'P2':yellow, 'P3':gray), \"Owner\" PEOPLE, \"Due\" DATE, \"Effort\" SELECT('XS':gray, 'S':blue, 'M':green, 'L':orange, 'XL':red), \"Project ID\" UNIQUE_ID PREFIX 'PRJ', \"Created\" CREATED_TIME)"
