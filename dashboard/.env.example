# Required: API key for /api/* (header x-api-key or Authorization: Bearer)
DASHBOARD_API_KEY=change-me

# Optional: Anthropic key forwarded to `claude` child (or rely on host env)
# ANTHROPIC_API_KEY=

# Login (browser session): all three required for POST /api/auth/login
DASHBOARD_ADMIN_USER=admin
DASHBOARD_ADMIN_PASSWORD=change-me
DASHBOARD_SESSION_SECRET=use-at-least-16-chars-here

# Optional overrides
# CLAUDE_BIN=claude
# DASHBOARD_AGENT_CWD=
# DASHBOARD_AGENT_PERMISSION_MODE=acceptEdits
# DASHBOARD_RATE_LIMIT_MAX=120
# DASHBOARD_RATE_LIMIT_WINDOW_MS=60000
# DASHBOARD_AGENT_TIMEOUT_MS=300000
